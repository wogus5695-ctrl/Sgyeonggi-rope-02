{
  "builds": [
    { "src": "api/ssr.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" },
    { "src": "favicon.ico", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/seoul/:region/:task", "destination": "/api/ssr.js?seoul_region=:region&seoul_task=:task" },
    { "source": "/", "destination": "/api/ssr.js" },
    { "source": "/index.html", "destination": "/api/ssr.js" }
  ]
}
